  {
    "id": "Monitoring_oci_scaffold_01",
    "title": "Object Storage — Object Count",
    "description": "ObjectCount metric from oci_objectstorage namespace, hourly sum",
    "type": "Line",
    "data": {
      "dataSource": "Monitoring",
      "api": {
        "templateId": "monitoring",
        "type": "urlTemplate",
        "variables": [
          {
            "compartmentId": {
              "value": "__COMPARTMENT_OCID__"
            },
            "namespace": {
              "value": "oci_objectstorage"
            },
            "query": {
              "value": "ObjectCount[1h].sum()"
            },
            "regionId": {
              "value": "__OCI_REGION__"
            },
            "resourceGroup": {}
          }
        ]
      }
    },
    "layout": {
      "height": 7,
      "left": 0,
      "minH": 6,
      "minW": 9,
      "top": 7,
      "width": 12
    }
  }
]
