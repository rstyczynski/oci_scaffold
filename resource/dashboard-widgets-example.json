[
  {
    "id": "LoggingChart_oci_scaffold_01",
    "title": "OCI Logging — Recent Logs",
    "description": "All log entries in the compartment, last 1 hour",
    "type": "Bar",
    "data": {
      "dataSource": "LoggingChart",
      "api": {
        "templateId": "loggingChart",
        "type": "urlTemplate",
        "variables": [
          {
            "fields": {
              "value": [
                "dashboard_log_table_datetime",
                "dashboard_log_table_type",
                "dashboard_log_table_data_message"
              ]
            },
            "groupBy": {
              "value": "data.result"
            },
            "mode": {
              "value": "advanced"
            },
            "regionId": {
              "value": "__OCI_REGION__"
            },
            "savedSearchCompartmentId": {},
            "savedSearchId": {},
            "searchQuery": {
              "value": "search \"__COMPARTMENT_OCID__\" | sort by datetime desc"
            },
            "xAxis": {
              "value": "rounddown(datetime, '1m')"
            },
            "yAxis": {
              "value": "data.result"
            }
          }
        ]
      }
    },
    "layout": {
      "height": 7,
      "left": 0,
      "minH": 3,
      "minW": 4,
      "top": 0,
      "width": 12
    }
  },
  {
